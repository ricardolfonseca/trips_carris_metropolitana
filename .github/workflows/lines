name: Fetch Carris Metropolitana Lines

on:
  schedule:
    - cron: '05 08 * * *'  
  workflow_dispatch:        # Allows manual trigger from GitHub UI

jobs:
  fetch-and-upload:
    runs-on: ubuntu-latest
    steps:
      - name: Fetch lines data
        run: curl -s https://api.carrismetropolitana.pt/v2/lines > lines.json

      - name: Setup Databricks CLI
        uses: databricks/setup-cli@main

      - name: Upload to Databricks Volume
        env:
          DATABRICKS_HOST: ${{ secrets.DATABRICKS_HOST }}
          DATABRICKS_TOKEN: ${{ secrets.DATABRICKS_TOKEN }}
        run: |
          databricks fs cp --overwrite lines.json "dbfs:/Volumes/trips_carris_metropolitana/bronze/lines/lines.json"
